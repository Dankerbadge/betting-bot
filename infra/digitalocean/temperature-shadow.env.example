# Copy to /etc/betbot/temperature-shadow.env on the droplet
# and edit values for your runtime.

# Absolute repo path on droplet.
BETBOT_ROOT=/opt/betting-bot

# Where strategy outputs/artifacts are written.
OUTPUT_DIR=/opt/betting-bot/outputs/pilot_candidate_do

# Absolute env file containing API credentials.
BETBOT_ENV_FILE=/etc/betbot/account_onboarding.local.env

# ColdMath hardening automation (timer + artifact pipeline).
COLDMATH_HARDENING_ENABLED=1
COLDMATH_WALLET_ADDRESS=0x594edb9112f526fa6a80b8f858a6379c8a2c1c11
COLDMATH_OUTPUT_DIR=/opt/betting-bot/outputs/pilot_candidate_do
COLDMATH_SNAPSHOT_DIR=/opt/betting-bot/tmp/coldmath_snapshot
COLDMATH_STALE_HOURS=48.0
COLDMATH_DATA_API_BASE_URL=https://data-api.polymarket.com
COLDMATH_GAMMA_BASE_URL=https://gamma-api.polymarket.com
COLDMATH_API_TIMEOUT_SECONDS=20.0
COLDMATH_POSITIONS_PAGE_SIZE=500
COLDMATH_POSITIONS_MAX_PAGES=20
COLDMATH_REFRESH_CLOSED_POSITIONS=1
COLDMATH_CLOSED_POSITIONS_PAGE_SIZE=50
COLDMATH_CLOSED_POSITIONS_MAX_PAGES=20
COLDMATH_REFRESH_TRADES=1
COLDMATH_REFRESH_ACTIVITY=1
COLDMATH_INCLUDE_TAKER_ONLY_TRADES=1
COLDMATH_INCLUDE_ALL_TRADE_ROLES=1
COLDMATH_TRADES_PAGE_SIZE=500
COLDMATH_TRADES_MAX_PAGES=20
COLDMATH_ACTIVITY_PAGE_SIZE=500
COLDMATH_ACTIVITY_MAX_PAGES=20
COLDMATH_MARKET_INGEST_ENABLED=1
COLDMATH_MARKET_INGEST_REFRESH_SNAPSHOT=0
COLDMATH_MARKET_MAX_MARKETS=500
COLDMATH_MARKET_PAGE_SIZE=200
COLDMATH_MARKET_MAX_PAGES=10
COLDMATH_MARKET_TIMEOUT_SECONDS=15.0
COLDMATH_MARKET_INCLUDE_INACTIVE=0
COLDMATH_REPLICATION_ENABLED=1
COLDMATH_REPLICATION_TOP_N=12
COLDMATH_REPLICATION_MARKET_TICKERS=
COLDMATH_REPLICATION_REQUIRE_LIQUIDITY_FILTER=1
COLDMATH_REPLICATION_REQUIRE_TWO_SIDED_QUOTES=1
COLDMATH_REPLICATION_MAX_SPREAD_DOLLARS=0.18
COLDMATH_REPLICATION_MIN_LIQUIDITY_SCORE=0.45
COLDMATH_REPLICATION_MAX_FAMILY_CANDIDATES=3
COLDMATH_REPLICATION_MAX_FAMILY_SHARE=0.60
COLDMATH_REPLICATION_EXCLUDED_MARKET_TICKERS=
COLDMATH_REPLICATION_USE_EXECUTION_COST_EXCLUSIONS=1
# execution_cost_tape_latest.json by default; override if you keep it elsewhere.
COLDMATH_REPLICATION_EXCLUDED_MARKET_TICKERS_FILE=/opt/betting-bot/outputs/pilot_candidate_do/health/execution_cost_tape_latest.json
# Repair pass can relax quote/liquidity gating to recover candidate breadth.
COLDMATH_REPLICATION_REPAIR_DISABLE_LIQUIDITY_FILTER=1
COLDMATH_REPLICATION_REPAIR_DISABLE_REQUIRE_TWO_SIDED_QUOTES=1
COLDMATH_EXECUTION_COST_TAPE_ENABLED=1
COLDMATH_EXECUTION_COST_TAPE_WINDOW_HOURS=168.0
COLDMATH_EXECUTION_COST_TAPE_MIN_CANDIDATE_SAMPLES=200
COLDMATH_EXECUTION_COST_TAPE_MIN_QUOTE_COVERAGE_RATIO=0.60
COLDMATH_EXECUTION_COST_TAPE_MAX_TICKERS=25
COLDMATH_EXECUTION_COST_TAPE_MIN_GLOBAL_EXPECTED_EDGE_SHARE_FOR_EXCLUSION=0.45
COLDMATH_EXECUTION_COST_TAPE_MIN_TICKER_ROWS_FOR_EXCLUSION=200
COLDMATH_EXECUTION_COST_TAPE_EXCLUSION_MAX_QUOTE_COVERAGE_RATIO=0.20
COLDMATH_EXECUTION_COST_TAPE_MAX_TICKER_MEAN_SPREAD_FOR_EXCLUSION=0.10
COLDMATH_EXECUTION_COST_TAPE_MAX_EXCLUDED_TICKERS=12
# Optional override; leave empty to use COLDMATH_OUTPUT_DIR/kalshi_execution_journal.sqlite3.
COLDMATH_EXECUTION_COST_TAPE_JOURNAL_DB_PATH=
COLDMATH_DECISION_MATRIX_ENABLED=1
COLDMATH_DECISION_MATRIX_WINDOW_HOURS=168.0
COLDMATH_DECISION_MATRIX_MIN_SETTLED_OUTCOMES=25
COLDMATH_DECISION_MATRIX_MAX_TOP_BLOCKER_SHARE=0.55
COLDMATH_DECISION_MATRIX_MIN_APPROVAL_RATE=0.03
COLDMATH_DECISION_MATRIX_MIN_INTENTS_SAMPLE=1000
COLDMATH_DECISION_MATRIX_MAX_SPARSE_EDGE_BLOCK_SHARE=0.80
COLDMATH_HARDENING_FAIL_ON_NOISE=0
COLDMATH_ACTIONABLE_MIN_POSITIONS_ROWS=100
COLDMATH_ACTIONABLE_MIN_CANDIDATES=4
COLDMATH_ACTIONABLE_MIN_MATCHED_RATIO=0.20
COLDMATH_ACTIONABLE_REQUIRE_INGEST=1
COLDMATH_ACTIONABLE_REQUIRE_REPLICATION=1
COLDMATH_ACTIONABLE_REQUIRE_DECISION_MATRIX=1
COLDMATH_ACTIONABLE_MIN_MATRIX_SCORE=75
COLDMATH_ACTIONABLE_ALLOWED_MATRIX_STATUSES=green,yellow
COLDMATH_ACTIONABLE_REQUIRE_MATRIX_SUPPORTS=1
# Allow decision matrix bootstrap signal when strict matrix gate is red during cold-start.
COLDMATH_ACTIONABLE_ALLOW_MATRIX_BOOTSTRAP=1
# Bootstrap expiry guard: disable bootstrap after this many hours from first bootstrap pass.
COLDMATH_ACTIONABLE_MATRIX_BOOTSTRAP_MAX_HOURS=336
# Bootstrap expiry guard: disable bootstrap once settled outcomes reach this count.
COLDMATH_ACTIONABLE_MATRIX_BOOTSTRAP_DISABLE_AT_SETTLED_OUTCOMES=25
# Optional persisted state path for bootstrap first/last seen tracking.
COLDMATH_ACTIONABLE_MATRIX_BOOTSTRAP_STATE_FILE=/opt/betting-bot/outputs/pilot_candidate_do/health/decision_matrix_bootstrap_state.json
# Optional lane-transition alerts (`strict`/`bootstrap`/`bootstrap_blocked`).
COLDMATH_LANE_ALERT_ENABLED=1
COLDMATH_LANE_ALERT_NOTIFY_STATUS_CHANGE_ONLY=1
# Falls back to PIPELINE_ALERT_WEBHOOK_URL, then RECOVERY_WEBHOOK_URL, then ALERT_WEBHOOK_URL.
COLDMATH_LANE_ALERT_WEBHOOK_URL=
# Falls back to PIPELINE_ALERT_WEBHOOK_THREAD_ID, then RECOVERY_WEBHOOK_THREAD_ID, then ALERT_WEBHOOK_THREAD_ID.
COLDMATH_LANE_ALERT_WEBHOOK_THREAD_ID=
COLDMATH_LANE_ALERT_WEBHOOK_TIMEOUT_SECONDS=5
COLDMATH_LANE_ALERT_WEBHOOK_USERNAME="BetBot Matrix Lane"
# concise or detailed
COLDMATH_LANE_ALERT_MESSAGE_MODE=concise
# CSV list of statuses treated as degraded for streak escalation.
COLDMATH_LANE_ALERT_DEGRADED_STATUSES=matrix_failed,bootstrap_blocked
# Trigger alert when degraded streak reaches this run count (0 disables streak escalation).
COLDMATH_LANE_ALERT_DEGRADED_STREAK_THRESHOLD=3
# After threshold is hit, notify every N additional degraded runs (0 defaults to threshold cadence).
COLDMATH_LANE_ALERT_DEGRADED_STREAK_NOTIFY_EVERY=3
# Optional dedupe/transition state file.
COLDMATH_LANE_ALERT_STATE_FILE=/opt/betting-bot/outputs/pilot_candidate_do/health/.decision_matrix_lane_alert_state.json

# Optional station/hour age override policy JSON.
# Leave empty to use global max age only.
METAR_AGE_POLICY_JSON=
# Optional calibrated SPECI shock policy JSON.
# Leave empty to use built-in defaults.
SPECI_CALIBRATION_JSON=

# Optional auto-generated METAR policy path used by alpha workers.
# When METAR_AGE_POLICY_JSON is empty and this file exists, shadow loop uses it automatically.
AUTO_METAR_POLICY_PATH=/opt/betting-bot/outputs/pilot_candidate_do/runtime/metar_age_policy_auto.json

# Loop cadence and execution constraints.
LOOP_SLEEP_SECONDS=60
MAX_ORDERS=8
MAX_MARKETS=200
MAX_INTENTS_PER_UNDERLYING=6
MAX_LIVE_SUBMISSIONS_PER_DAY=3
# Leave blank to inherit DAILY_RISK_CAP_DOLLARS automatically.
MAX_LIVE_COST_PER_DAY_DOLLARS=
MAX_METAR_AGE_MINUTES=22.5
# Replan cooldown reduces repeated market-side churn in consecutive loops.
REPLAN_MARKET_SIDE_COOLDOWN_MINUTES=20
REPLAN_MARKET_SIDE_PRICE_CHANGE_OVERRIDE_DOLLARS=0.02
REPLAN_MARKET_SIDE_ALPHA_CHANGE_OVERRIDE=0.2
REPLAN_MARKET_SIDE_CONFIDENCE_CHANGE_OVERRIDE=0.03
REPLAN_MARKET_SIDE_MIN_OBSERVATION_ADVANCE_MINUTES=2
# Independent-breadth guardrail: cap repeated plans per market-side in rolling window.
REPLAN_MARKET_SIDE_REPEAT_WINDOW_MINUTES=1440
REPLAN_MARKET_SIDE_MAX_PLANS_PER_WINDOW=8
REPLAN_MARKET_SIDE_HISTORY_FILES=180
REPLAN_MARKET_SIDE_MIN_ORDERS_BACKSTOP=1
# Optional adaptive replan cooldown tuning (bounded + data-backed).
REPLAN_COOLDOWN_ADAPTIVE_ENABLED=1
REPLAN_COOLDOWN_ADAPTIVE_MINUTES_MIN=8
REPLAN_COOLDOWN_ADAPTIVE_MINUTES_MAX=35
REPLAN_COOLDOWN_ADAPTIVE_STEP_UP_MINUTES=2
REPLAN_COOLDOWN_ADAPTIVE_STEP_DOWN_MINUTES=2
REPLAN_COOLDOWN_ADAPTIVE_TARGET_BLOCKED_RATIO=0.55
REPLAN_COOLDOWN_ADAPTIVE_BAND_RATIO=0.15
REPLAN_COOLDOWN_ADAPTIVE_MAX_OVERRIDE_RATIO=0.30
REPLAN_COOLDOWN_ADAPTIVE_MIN_INPUT_COUNT=25
REPLAN_COOLDOWN_ADAPTIVE_MIN_PLANNED_FOR_UP=6
REPLAN_COOLDOWN_ADAPTIVE_BACKSTOP_RELEASE_THRESHOLD=1
REPLAN_COOLDOWN_ADAPTIVE_UP_STREAK_REQUIRED=2
REPLAN_COOLDOWN_ADAPTIVE_DOWN_STREAK_REQUIRED=2
# Adaptive min-orders backstop tuning for cooldown-starved cycles.
REPLAN_BACKSTOP_ADAPTIVE_ENABLED=1
REPLAN_BACKSTOP_ADAPTIVE_MIN=1
REPLAN_BACKSTOP_ADAPTIVE_MAX=24
REPLAN_BACKSTOP_ADAPTIVE_STEP_UP=1
REPLAN_BACKSTOP_ADAPTIVE_STEP_DOWN=1
REPLAN_BACKSTOP_ADAPTIVE_TARGET_BLOCKED_RATIO=0.70
REPLAN_BACKSTOP_ADAPTIVE_BAND_RATIO=0.12
REPLAN_BACKSTOP_ADAPTIVE_TARGET_PLANNED_RATIO=0.30
REPLAN_BACKSTOP_ADAPTIVE_APPROVAL_MIN_RATIO=0.35
REPLAN_BACKSTOP_ADAPTIVE_STALE_MAX_RATIO=0.20
REPLAN_BACKSTOP_ADAPTIVE_MAX_OVERRIDE_RATIO=0.35
REPLAN_BACKSTOP_ADAPTIVE_MIN_INPUT_COUNT=20
# Only step backstop up when planned unique market-sides are increasing.
REPLAN_BACKSTOP_ADAPTIVE_REQUIRE_BREADTH_RISE=1
REPLAN_BACKSTOP_ADAPTIVE_MIN_UNIQUE_MARKET_SIDES_FOR_UP=4
# Also require minimum unique underlying families before allowing step-ups.
REPLAN_BACKSTOP_ADAPTIVE_MIN_UNIQUE_UNDERLYINGS_FOR_UP=2
REPLAN_BACKSTOP_ADAPTIVE_MAX_RESPECT_RISK_BUDGET=1
# Deadlock breaker: after repeated blocked-without-breadth-rise cycles,
# allow one bounded relief step-up if quality guardrails are still clean.
REPLAN_BACKSTOP_ADAPTIVE_STAGNATION_RELIEF_ENABLED=1
REPLAN_BACKSTOP_ADAPTIVE_STAGNATION_RELIEF_MIN_CYCLES=4
# Throughput-release preset (optional; use when cooldown blocks stay high
# and selected plans remain pinned low despite healthy approval/stale rates):
# REPLAN_BACKSTOP_ADAPTIVE_MAX=24
# REPLAN_BACKSTOP_ADAPTIVE_STEP_UP=2
# REPLAN_BACKSTOP_ADAPTIVE_TARGET_BLOCKED_RATIO=0.65
# REPLAN_BACKSTOP_ADAPTIVE_REQUIRE_BREADTH_RISE=0
# REPLAN_BACKSTOP_ADAPTIVE_STAGNATION_RELIEF_MIN_CYCLES=2
# METAR ingest network timeout for normal cycles.
METAR_TIMEOUT_SECONDS=20
TAF_STALE_GRACE_MINUTES=2.5
TAF_STALE_GRACE_MAX_VOLATILITY_SCORE=1.0
TAF_STALE_GRACE_MAX_RANGE_WIDTH=10.0
# Near-stale quality tightening: when METAR age approaches the effective max
# age boundary, require stronger modeled quality before approval.
METAR_FRESHNESS_QUALITY_BOUNDARY_RATIO=0.92
METAR_FRESHNESS_QUALITY_PROBABILITY_MARGIN=0.03
METAR_FRESHNESS_QUALITY_EXPECTED_EDGE_MARGIN=0.005
YES_MAX_ENTRY_PRICE_DOLLARS=0.95
NO_MAX_ENTRY_PRICE_DOLLARS=0.95
# Adaptive entry-cap relief: when expected-edge blockers dominate with healthy
# freshness/finalization metrics, lower entry caps in bounded steps instead of
# loosening confidence thresholds. Keeps quality hardening in place.
ADAPTIVE_ENTRY_CAP_RELIEF_ENABLED=1
ADAPTIVE_ENTRY_CAP_RELIEF_MIN_PRICE=0.80
ADAPTIVE_ENTRY_CAP_RELIEF_STEP_DOWN=0.02
ADAPTIVE_ENTRY_CAP_RELIEF_STEP_UP=0.01
ADAPTIVE_ENTRY_CAP_RELIEF_MIN_INTENTS=120
ADAPTIVE_ENTRY_CAP_RELIEF_EDGE_RATE_THRESHOLD=0.30
ADAPTIVE_ENTRY_CAP_RELIEF_EDGE_RATE_EXTREME_THRESHOLD=0.50
ADAPTIVE_ENTRY_CAP_RELIEF_MAX_APPROVAL_RATE=0.12
ADAPTIVE_ENTRY_CAP_RELIEF_MAX_STALE_RATE=0.20
ADAPTIVE_ENTRY_CAP_RELIEF_MAX_SETTLEMENT_BLOCKED_RATE=0.15
ADAPTIVE_ENTRY_CAP_RELIEF_RECOVERY_EDGE_RATE=0.20
ADAPTIVE_ENTRY_CAP_RELIEF_RECOVERY_APPROVAL_RATE=0.25
ADAPTIVE_ENTRY_CAP_RELIEF_STREAK_ESCALATION_ENABLED=1
ADAPTIVE_ENTRY_CAP_RELIEF_STREAK_MIN_CYCLES=4
ADAPTIVE_ENTRY_CAP_RELIEF_STREAK_STEP_MULTIPLIER=1.75
ADAPTIVE_ENTRY_CAP_RELIEF_STREAK_EXTREME_STEP_MULTIPLIER=2.50
ADAPTIVE_ENTRY_CAP_RELIEF_SETTLEMENT_DAMPEN_FACTOR=0.50
ADAPTIVE_ENTRY_CAP_RELIEF_STREAK_DECAY_PER_CYCLE=1

# Shadow sim sizing profile (reference bankroll + lot sizing)
PLANNING_BANKROLL_DOLLARS=1000
RISK_PER_ORDER_PCT=1.0
DAILY_RISK_CAP_PCT=10.0
# Portfolio deployment + concentration limits per loop.
MAX_TOTAL_DEPLOYED_PCT=0.35
MAX_SAME_STATION_EXPOSURE_PCT=0.60
MAX_SAME_HOUR_CLUSTER_EXPOSURE_PCT=0.60
MAX_SAME_UNDERLYING_EXPOSURE_PCT=0.50
# Optional hard overrides (leave blank to auto-derive from the profile above):
# CONTRACTS_PER_ORDER=
# DAILY_RISK_CAP_DOLLARS=
MIN_SETTLEMENT_CONFIDENCE=0.60
MIN_ALPHA_STRENGTH=0.0
# Optional quality gates (set blank to disable). These are enforced during
# approval, not just in reporting.
# MIN_PROBABILITY_CONFIDENCE=0.72
# MIN_EXPECTED_EDGE_NET=0.035
# MIN_EDGE_TO_RISK_RATIO=0.03
# Explicit probability/edge enforcement controls (recommended pinned defaults).
ENFORCE_PROBABILITY_EDGE_THRESHOLDS=1
# Raise fallback probability threshold for expensive entries when defaulted.
ENFORCE_ENTRY_PRICE_PROBABILITY_FLOOR=1
# Leave blank to follow effective min-settlement-confidence each cycle.
FALLBACK_MIN_PROBABILITY_CONFIDENCE=
FALLBACK_MIN_EXPECTED_EDGE_NET=0.005
FALLBACK_MIN_EDGE_TO_RISK_RATIO=0.02
# Optional runtime quality-gate auto profile generated by alpha summary.
# When enabled, shadow loop reads the runtime profile file and uses it as
# effective min-* gates (falls back to env gates if missing/stale).
APPROVAL_GATE_PROFILE_AUTO_ENABLED=1
APPROVAL_GATE_PROFILE_AUTO_PATH=/opt/betting-bot/outputs/pilot_candidate_do/runtime/approval_gate_profile_auto.json
APPROVAL_GATE_PROFILE_AUTO_MAX_AGE_SECONDS=172800
# Approval guardrail runtime controller: tighten when approval rate is too high,
# and apply bounded starvation relief when approval rate is too low while stale/
# settlement pressure stays clean.
APPROVAL_GUARDRAIL_ESCALATION_ENABLED=1
APPROVAL_GUARDRAIL_ESCALATION_MIN_INTENTS=150
APPROVAL_GUARDRAIL_ESCALATION_SETTLEMENT_STEP=0.02
APPROVAL_GUARDRAIL_ESCALATION_ALPHA_STEP=0.15
APPROVAL_GUARDRAIL_ESCALATION_PROBABILITY_STEP=0.03
APPROVAL_GUARDRAIL_ESCALATION_EDGE_STEP=0.005
APPROVAL_GUARDRAIL_ESCALATION_SETTLEMENT_MAX=0.99
APPROVAL_GUARDRAIL_ESCALATION_ALPHA_MAX=10.0
APPROVAL_GUARDRAIL_ESCALATION_PROBABILITY_MAX=0.995
APPROVAL_GUARDRAIL_ESCALATION_EDGE_MAX=0.25
APPROVAL_GUARDRAIL_ESCALATION_CRITICAL_MULTIPLIER=2.0
APPROVAL_GUARDRAIL_ESCALATION_ABOVE_BAND_STEP_RATE=0.03
APPROVAL_GUARDRAIL_ESCALATION_MAX_MULTIPLIER=4.0
APPROVAL_GUARDRAIL_RELAXATION_ENABLED=1
APPROVAL_GUARDRAIL_RELAXATION_STATE_FILE=/opt/betting-bot/outputs/pilot_candidate_do/.approval_guardrail_relaxation.json
APPROVAL_GUARDRAIL_RELAXATION_MIN_INTENTS=150
APPROVAL_GUARDRAIL_RELAXATION_MIN_STREAK_CYCLES=3
APPROVAL_GUARDRAIL_RELAXATION_MAX_STALE_RATE=0.20
APPROVAL_GUARDRAIL_RELAXATION_MAX_SETTLEMENT_BLOCKED_RATE=0.20
APPROVAL_GUARDRAIL_RELAXATION_MIN_EDGE_BLOCKED_RATE=0.25
APPROVAL_GUARDRAIL_RELAXATION_STEP_MULTIPLIER=1.25
APPROVAL_GUARDRAIL_RELAXATION_EXTREME_STEP_MULTIPLIER=2.0
APPROVAL_GUARDRAIL_RELAXATION_DECAY_PER_CYCLE=1
# Allow starvation relief to key off latest-cycle below-band approvals even when
# the guardrail sample source is rolling fallback.
APPROVAL_GUARDRAIL_RELAXATION_ALLOW_LATEST_OVERRIDE=1
APPROVAL_GUARDRAIL_RELAXATION_LATEST_MIN_INTENTS=100
# Minimum divergence required before latest-cycle signal can override/blend
# rolling-window fallback guardrail sampling.
APPROVAL_GUARDRAIL_RELAXATION_LATEST_DIVERGENCE_MIN=0.05
APPROVAL_GUARDRAIL_RELAXATION_MIN_SETTLEMENT=0.50
APPROVAL_GUARDRAIL_RELAXATION_MIN_ALPHA=0.0
APPROVAL_GUARDRAIL_RELAXATION_MIN_PROBABILITY=0.50
APPROVAL_GUARDRAIL_RELAXATION_MIN_EDGE=0.0
MAX_YES_POSSIBLE_GAP_FOR_YES_SIDE=0.0
ENFORCE_INTERVAL_CONSISTENCY=1
# Adaptive interval-gap controller (for yes-side interval consistency only).
# Keeps hard interval gate enabled while boundedly relaxing/tightening max gap
# when overlap blockers persist under fresh + low-stale conditions.
ADAPTIVE_INTERVAL_GAP_ENABLED=0
ADAPTIVE_INTERVAL_GAP_MIN=0.0
ADAPTIVE_INTERVAL_GAP_MAX=1.0
ADAPTIVE_INTERVAL_GAP_STEP_UP=0.05
ADAPTIVE_INTERVAL_GAP_STEP_DOWN=0.03
ADAPTIVE_INTERVAL_GAP_MIN_INTENTS=120
ADAPTIVE_INTERVAL_GAP_TARGET_RANGE_RATE=0.10
ADAPTIVE_INTERVAL_GAP_EXTREME_RANGE_RATE=0.18
ADAPTIVE_INTERVAL_GAP_HYSTERESIS_RATE=0.03
ADAPTIVE_INTERVAL_GAP_MAX_STALE_RATE=0.18
ADAPTIVE_INTERVAL_GAP_MIN_APPROVAL_RATE=0.08

# Optional adaptive scan budgeting for constrained hosts (0=disabled, 1=enabled).
ADAPTIVE_MAX_MARKETS_ENABLED=1
ADAPTIVE_MAX_MARKETS_MIN=60
ADAPTIVE_MAX_MARKETS_MAX=9000
ADAPTIVE_MAX_MARKETS_TARGET_SECONDS=55
ADAPTIVE_MAX_MARKETS_STEP_UP=8
ADAPTIVE_MAX_MARKETS_STEP_DOWN=12
# Host-saturation hysteresis for adaptive max-markets (shared CPU-friendly).
ADAPTIVE_HOST_SATURATION_LOAD_HIGH_MILLI=1300
ADAPTIVE_HOST_SATURATION_LOAD_CRITICAL_MILLI=1550
ADAPTIVE_HOST_SATURATION_MIN_CYCLE_PCT_OF_TARGET=90
ADAPTIVE_HOST_SATURATION_STEP_DOWN_MULTIPLIER=1
ADAPTIVE_HOST_SATURATION_STEP_DOWN_CRITICAL_MULTIPLIER=2
# Data-backed adaptive scan guardrails (keep broad + robust, avoid overfitting).
ADAPTIVE_STALE_RATE_HIGH_THRESHOLD=0.35
ADAPTIVE_APPROVAL_RATE_LOW_THRESHOLD=0.12
ADAPTIVE_APPROVAL_RATE_HIGH_THRESHOLD=0.35
ADAPTIVE_DECISION_MIN_INTENTS=50
# When range-overlap blockers dominate with low stale pressure, expand scan scope.
ADAPTIVE_RANGE_POSSIBLE_MIN_INTENTS=50
ADAPTIVE_RANGE_POSSIBLE_RATE_HIGH_THRESHOLD=0.08
ADAPTIVE_RANGE_POSSIBLE_RATE_EXTREME_THRESHOLD=0.15
ADAPTIVE_RANGE_POSSIBLE_ROLLING_WINDOW_TAG=4h
ADAPTIVE_RANGE_POSSIBLE_ROLLING_METRICS_MAX_AGE_SECONDS=21600
# When cutoff blockers rise, tighten scan scope and sleep to arrive earlier near close.
ADAPTIVE_CUTOFF_PRESSURE_ENABLED=1
ADAPTIVE_CUTOFF_PRESSURE_MIN_INTENTS=75
ADAPTIVE_CUTOFF_PRESSURE_RATE_THRESHOLD=0.02
ADAPTIVE_CUTOFF_PRESSURE_RATE_EXTREME_THRESHOLD=0.05
ADAPTIVE_CUTOFF_PRESSURE_MAX_LOAD_MILLI=1100
CUTOFF_PRESSURE_SLEEP_SECONDS=3
CUTOFF_PRESSURE_HOLD_CYCLES=2
# When underlying exposure caps dominate, adapt per-underlying throughput with
# guardrails so we favor breadth when overlap is high and relieve caps only when
# stale/approval quality is clean.
ADAPTIVE_UNDERLYING_CAP_PRESSURE_ENABLED=1
ADAPTIVE_UNDERLYING_CAP_PRESSURE_MIN_INTENTS=80
ADAPTIVE_UNDERLYING_CAP_PRESSURE_RATE_THRESHOLD=0.03
ADAPTIVE_UNDERLYING_CAP_PRESSURE_RATE_EXTREME_THRESHOLD=0.06
ADAPTIVE_UNDERLYING_CAP_PRESSURE_MAX_STALE_RATE=0.20
ADAPTIVE_UNDERLYING_CAP_PRESSURE_MIN_APPROVAL_RATE=0.20
ADAPTIVE_UNDERLYING_CAP_RANGE_DIVERSIFY_THRESHOLD=0.08
ADAPTIVE_MAX_INTENTS_PER_UNDERLYING_MIN=6
ADAPTIVE_MAX_INTENTS_PER_UNDERLYING_MAX=20
ADAPTIVE_MAX_INTENTS_PER_UNDERLYING_STEP=2
# Freeze adaptive decisions when their source artifacts are stale.
ADAPTIVE_BLOCKER_METRICS_MAX_AGE_SECONDS=300
ADAPTIVE_SETTLEMENT_METRICS_MAX_AGE_SECONDS=900
ADAPTIVE_REPLAN_METRICS_MAX_AGE_SECONDS=300

# Contract-spec refresh cadence (seconds). Keep slower than trading loop.
CONTRACT_SPECS_REFRESH_SECONDS=900

# Keep shadow mode unless intentionally promoting.
ALLOW_LIVE_ORDERS=0

# Trade gate safety defaults.
ENFORCE_TRADE_GATE=1
ENFORCE_WS_STATE_AUTHORITY=0
WS_STATE_MAX_AGE_SECONDS=30

# Final-report lookup behavior for settlement-state refresh.
SETTLEMENT_TOP_N=80
FINAL_REPORT_CACHE_TTL_MINUTES=15
FINAL_REPORT_TIMEOUT_SECONDS=12
# Settlement-state refresh cadence (seconds). Keep slower than trading loop.
SETTLEMENT_REFRESH_SECONDS=180
# Adaptive settlement refresh tightens cadence and lookup breadth when
# settlement_finalization_blocked / pending_final_report pressure is elevated.
SETTLEMENT_REFRESH_ADAPTIVE_ENABLED=1
SETTLEMENT_REFRESH_MIN_SECONDS=60
SETTLEMENT_REFRESH_PRESSURE_MIN_COUNT=8
SETTLEMENT_REFRESH_PRESSURE_MIN_RATE=0.03
SETTLEMENT_REFRESH_PRESSURE_MIN_PENDING=1
SETTLEMENT_TOP_N_PRESSURE_MAX=260
SETTLEMENT_TOP_N_PRESSURE_BLOCKED_DIVISOR=6
SETTLEMENT_TOP_N_PRESSURE_BLOCKED_UNDERLYING_MULTIPLIER=3
SETTLEMENT_TOP_N_PRESSURE_HOLD_FLOOR=60
FINAL_REPORT_CACHE_TTL_MINUTES_PRESSURE=2
SETTLEMENT_PRESSURE_HOLD_CYCLES=3
SETTLEMENT_PRESSURE_FORCE_REFRESH_SECONDS=15
SETTLEMENT_PRESSURE_RETRY_ATTEMPTS=4
