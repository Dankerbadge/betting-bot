BREADTH_TOP_N=60
BREADTH_TIMEOUT_SECONDS=12
BREADTH_MIN_SETTLEMENT_CONFIDENCE=0.60
BREADTH_MIN_ALPHA_STRENGTH=0.0
# BREADTH_MIN_PROBABILITY_CONFIDENCE=0.72
# BREADTH_MIN_EXPECTED_EDGE_NET=0.035
# BREADTH_MIN_EDGE_TO_RISK_RATIO=0.03
BREADTH_ENFORCE_PROBABILITY_EDGE_THRESHOLDS=1
BREADTH_ENFORCE_ENTRY_PRICE_PROBABILITY_FLOOR=1
# Leave blank to follow BREADTH_MIN_SETTLEMENT_CONFIDENCE each cycle.
BREADTH_FALLBACK_MIN_PROBABILITY_CONFIDENCE=
BREADTH_FALLBACK_MIN_EXPECTED_EDGE_NET=0.005
BREADTH_FALLBACK_MIN_EDGE_TO_RISK_RATIO=0.02
BREADTH_MAX_MARKETS_ADAPTIVE_ENABLED=1
BREADTH_MAX_MARKETS_MIN=1600
BREADTH_MAX_MARKETS_MAX=8000
BREADTH_MAX_MARKETS_TARGET_SCAN_SECONDS=30
BREADTH_MAX_MARKETS_TARGET_SCAN_SLACK_SECONDS=6
BREADTH_MAX_MARKETS_TARGET_SCAN_HARD_SLACK_SECONDS=12
BREADTH_MAX_MARKETS_STEP_UP=180
BREADTH_MAX_MARKETS_STEP_UP_FAST=360
BREADTH_MAX_MARKETS_STEP_DOWN=220
BREADTH_MAX_MARKETS_STEP_DOWN_FAST=420
BREADTH_TARGET_PRESSURE_CAP_MULTIPLIER=1.5
BREADTH_RELAXED_GAP_PRIMARY=3.0
BREADTH_RELAXED_GAP_WIDE=6.0
BREADTH_RELAXED_GAP_ULTRA=8.0
BREADTH_RELAXED_AGE_PRIMARY=26.0
BREADTH_RELAXED_AGE_WIDE=30.0
BREADTH_RELAXED_AGE_ULTRA=34.0
BREADTH_TAF_STALE_GRACE_MINUTES=2.5
BREADTH_TAF_STALE_GRACE_MAX_VOLATILITY_SCORE=1.0
BREADTH_TAF_STALE_GRACE_MAX_RANGE_WIDTH=10.0
BREADTH_ENABLE_WIDE_GAP_PROFILE=1
BREADTH_ENABLE_ULTRA_GAP_PROFILE=1
BREADTH_ENABLE_ULTRA_AGE_ONLY_PROFILE=1
BREADTH_PROFILE_PARALLELISM_ADAPTIVE_ENABLED=1
BREADTH_PROFILE_PARALLELISM_MIN=2
BREADTH_PROFILE_PARALLELISM_MAX=8
BREADTH_ADAPTIVE_LOAD_VERY_LOW_MILLI=140
BREADTH_ADAPTIVE_LOAD_LOW_MILLI=260
BREADTH_ADAPTIVE_LOAD_HIGH_MILLI=760
BREADTH_ADAPTIVE_LOAD_VERY_HIGH_MILLI=920
BREADTH_ADAPTIVE_PARALLELISM_STEP_UP=1
BREADTH_ADAPTIVE_PARALLELISM_STEP_UP_FAST=2
BREADTH_ADAPTIVE_PARALLELISM_STEP_DOWN=1
BREADTH_ADAPTIVE_PARALLELISM_STEP_DOWN_FAST=2

# Faster viability/alpha-gap refresh for short feedback loops.
ALPHA_VALIDATION_REFRESH_SECONDS=900
ALPHA_VALIDATION_HOURS=14
ALPHA_VALIDATION_TOP_N=30
ALPHA_VALIDATION_SLIPPAGE_BPS_LIST=0,5,10
# Keep disabled when betbot-temperature-reporting.timer is active to avoid
# duplicate heavy readiness/bankroll rollups.
ALPHA_VALIDATION_ROLLUPS_ENABLED=0
ALPHA_READINESS_HORIZONS=1d,7d,14d,21d,28d,3mo,6mo,1yr
ALPHA_DASHBOARD_REFRESH_SECONDS=60

# Weekly top-20 blocker audit (non-approved reasons).
BLOCKER_AUDIT_HOURS=168
BLOCKER_AUDIT_TOP_N=20
BLOCKER_AUDIT_SEND_WEBHOOK=1
# concise sends top 3 blocker actions to Discord; detailed sends top 5.
BLOCKER_AUDIT_DISCORD_MODE=concise
# Falls back to ALPHA_SUMMARY_WEBHOOK_URL, then ALERT_WEBHOOK_URL.
BLOCKER_AUDIT_WEBHOOK_URL=
# Optional Discord thread id (falls back to ALPHA_SUMMARY_WEBHOOK_ALPHA_THREAD_ID, then ALPHA_SUMMARY_WEBHOOK_THREAD_ID).
BLOCKER_AUDIT_WEBHOOK_THREAD_ID=
BLOCKER_AUDIT_WEBHOOK_TIMEOUT_SECONDS=5
BLOCKER_AUDIT_WEBHOOK_USERNAME="BetBot Ops"

# Optional CDO prewarm worker (requires history CSV from non-sports capture).
ALPHA_PREWARM_ENABLED=0
ALPHA_PREWARM_REFRESH_SECONDS=3600
ALPHA_PREWARM_HISTORY_CSV=/opt/betting-bot/outputs/kalshi_nonsports_history.csv
ALPHA_PREWARM_MAX_STATION_DAY_KEYS=200
ALPHA_PREWARM_TIMEOUT_SECONDS=12

# Machine-readable cycle health status output + stale thresholds.
HEALTH_STATUS_DIR=
HEALTH_STATUS_FILE=
HEALTH_METAR_STALE_WARN_SECONDS=180
HEALTH_METAR_STALE_CRIT_SECONDS=600
HEALTH_SETTLEMENT_STALE_WARN_SECONDS=600
HEALTH_SETTLEMENT_STALE_CRIT_SECONDS=1800
HEALTH_SHADOW_STALE_WARN_SECONDS=180
HEALTH_SHADOW_STALE_CRIT_SECONDS=900
HEALTH_READINESS_STALE_WARN_SECONDS=21600
HEALTH_RANGE_FAMILY_CONFLICT_WARN_COUNT=25
HEALTH_MONOTONIC_VIOLATION_WARN_COUNT=25
# Approval-rate guardrail for live health status and Discord alerts.
HEALTH_APPROVAL_RATE_MIN_RATIO=0.03
HEALTH_APPROVAL_RATE_MAX_RATIO=0.20
HEALTH_APPROVAL_RATE_MIN_INTENTS=100
HEALTH_APPROVAL_RATE_CRITICAL_HIGH_RATIO=0.50

# Fast SPECI-triggered rescan behavior.
FAST_RESCAN_ENABLED=1
FAST_RESCAN_SLEEP_SECONDS=3
FAST_RESCAN_MIN_DELTA_C=1.5
FAST_RESCAN_MAX_OBS_AGE_MINUTES=12

# Freshness-pressure mode (data-backed): tightens METAR timeout/retries/sleep
# only when stale suppression is materially elevated on meaningful sample size.
FRESHNESS_PRESSURE_ENABLED=1
FRESHNESS_PRESSURE_MIN_INTENTS=75
FRESHNESS_PRESSURE_STALE_COUNT_THRESHOLD=250
FRESHNESS_PRESSURE_STALE_RATE_THRESHOLD=0.20
FRESHNESS_PRESSURE_METAR_TIMEOUT_SECONDS=35
FRESHNESS_PRESSURE_METAR_RETRY_ATTEMPTS=3
FRESHNESS_PRESSURE_SLEEP_SECONDS=20
# Anti-flap hysteresis: once activated, keep pressure mode active for this
# many cycles after the raw trigger falls below threshold.
FRESHNESS_PRESSURE_HOLD_CYCLES=3

# Optional status/milestone webhook alerts (Slack-compatible JSON payload).
ALERT_WEBHOOK_URL=
# Optional default Discord thread id for bot alerts.
ALERT_WEBHOOK_THREAD_ID=
ALERT_WEBHOOK_TIMEOUT_SECONDS=5
# Optional dedicated webhook for shadow-loop health + milestone events.
# Falls back to ALERT_WEBHOOK_URL when unset.
SHADOW_ALERT_WEBHOOK_URL=
# Optional Discord thread id (falls back to ALERT_WEBHOOK_THREAD_ID).
SHADOW_ALERT_WEBHOOK_THREAD_ID=
SHADOW_ALERT_WEBHOOK_TIMEOUT_SECONDS=5
SHADOW_ALERT_WEBHOOK_USERNAME="BetBot Shadow Health"
ALERT_NOTIFY_YELLOW=1
ALERT_NOTIFY_RED=1
ALERT_NOTIFY_MILESTONE=1
ALERT_NOTIFY_STATUS_CHANGE_ONLY=1
# concise or detailed
ALERT_MESSAGE_MODE=concise
# Optional strict webhook routing enforcement:
# when 1, webhook-routing audit exits non-zero if multiple bots share the same
# effective route (same webhook + same thread id).
DISCORD_WEBHOOK_SEPARATION_STRICT=0

# Optional dedicated webhook for pipeline alerts from readiness reports.
# Falls back to RECOVERY_WEBHOOK_URL or ALERT_WEBHOOK_URL when unset.
PIPELINE_ALERT_WEBHOOK_URL=
# Optional Discord thread id (falls back to RECOVERY_WEBHOOK_THREAD_ID, then ALERT_WEBHOOK_THREAD_ID).
PIPELINE_ALERT_WEBHOOK_THREAD_ID=
PIPELINE_ALERT_WEBHOOK_TIMEOUT_SECONDS=5
PIPELINE_ALERT_WEBHOOK_USERNAME="BetBot Pipeline"
# Suppress duplicate pipeline alerts when status/reason have not changed.
PIPELINE_ALERT_NOTIFY_STATUS_CHANGE_ONLY=1
# concise or detailed
PIPELINE_ALERT_MESSAGE_MODE=concise
# Optional persisted fingerprint file for dedupe state.
PIPELINE_ALERT_STATE_FILE=

# Pipeline recovery watchdog (run via systemd timer).
# This service auto-remediates stale pipeline states and failed services.
RECOVERY_DIR=
RECOVERY_STATE_FILE=
RECOVERY_LATEST_FILE=
RECOVERY_LOG_FILE=
RECOVERY_RUN_AS_USER=betbot
RECOVERY_MAX_EVENT_FILES=240

RECOVERY_ENABLE_SERVICE_RESTARTS=1
RECOVERY_ENABLE_METAR_REFRESH=1
RECOVERY_ENABLE_SETTLEMENT_REFRESH=1
RECOVERY_ENABLE_REPORTING_TRIGGER=1
RECOVERY_ENABLE_ALPHA_SUMMARY_TRIGGER=1
# Worker self-heal controls (breadth expansion services).
RECOVERY_ENABLE_ALPHA_WORKER_RESTARTS=1
RECOVERY_ENABLE_BREADTH_WORKER_RESTARTS=1
# Auto-enable/start log-maintenance timer when inactive.
RECOVERY_ENABLE_LOG_MAINTENANCE_TIMER_ENABLE=1
# Log maintenance auto-trigger controls.
RECOVERY_ENABLE_LOG_MAINTENANCE_TRIGGER=1
# Defaults inherit ALPHA_WORKER_ENABLED / BREADTH_WORKER_ENABLED when unset.
RECOVERY_REQUIRE_ALPHA_WORKER=
RECOVERY_REQUIRE_BREADTH_WORKER=
# Ensure log-maintenance timer is running (recommended).
RECOVERY_REQUIRE_LOG_MAINTENANCE_TIMER=1
# Ensure alpha-summary timer is running (recommended).
RECOVERY_REQUIRE_ALPHA_SUMMARY_TIMER=1

RECOVERY_HEALTH_STALE_CRIT_SECONDS=900
RECOVERY_READINESS_STALE_CRIT_SECONDS=21600
RECOVERY_ALPHA_SUMMARY_STALE_CRIT_SECONDS=46800
RECOVERY_REPORTING_ACTIVATING_CRIT_SECONDS=2700
RECOVERY_LOG_MAINTENANCE_STALE_CRIT_SECONDS=7200
# Optional: trigger maintenance when latest log health is yellow (default off).
RECOVERY_LOG_MAINTENANCE_TRIGGER_ON_YELLOW=0
# When enabled, a long-activating reporting run is restarted only if readiness
# is stale/missing or pipeline is red (prevents false restart churn).
RECOVERY_REPORTING_ACTIVATING_RESTART_REQUIRE_STALE=1
RECOVERY_RED_CONSECUTIVE_THRESHOLD=2
RECOVERY_PIPELINE_RED_CONSECUTIVE_THRESHOLD=2
RECOVERY_FRESHNESS_PRESSURE_CONSECUTIVE_THRESHOLD=3
RECOVERY_RETRY_PRESSURE_CONSECUTIVE_THRESHOLD=3
RECOVERY_FRESHNESS_STALE_RATE_CRIT=0.20
RECOVERY_FRESHNESS_MIN_INTENTS=100

RECOVERY_SHADOW_RESTART_COOLDOWN_SECONDS=900
RECOVERY_REPORTING_RESTART_COOLDOWN_SECONDS=900
RECOVERY_ALPHA_WORKER_RESTART_COOLDOWN_SECONDS=900
RECOVERY_BREADTH_WORKER_RESTART_COOLDOWN_SECONDS=900
RECOVERY_METAR_REFRESH_COOLDOWN_SECONDS=300
RECOVERY_SETTLEMENT_REFRESH_COOLDOWN_SECONDS=300
RECOVERY_REPORTING_TRIGGER_COOLDOWN_SECONDS=300
RECOVERY_ALPHA_SUMMARY_TRIGGER_COOLDOWN_SECONDS=900
RECOVERY_LOG_MAINTENANCE_TIMER_ENABLE_COOLDOWN_SECONDS=900
RECOVERY_LOG_MAINTENANCE_TRIGGER_COOLDOWN_SECONDS=900
RECOVERY_SCAN_BUDGET_TRIM_COOLDOWN_SECONDS=900
RECOVERY_SCAN_BUDGET_TRIM_FACTOR=0.85
RECOVERY_SCAN_BUDGET_TRIM_MIN=400
RECOVERY_ENABLE_SCAN_BUDGET_TRIM=1
RECOVERY_LOG_MAINTENANCE_SERVICE_NAME=betbot-temperature-log-maintenance.service
RECOVERY_LOG_MAINTENANCE_TIMER_NAME=betbot-temperature-log-maintenance.timer

# Optional dedicated webhook for recovery alerts.
# Falls back to ALERT_WEBHOOK_URL when unset.
RECOVERY_WEBHOOK_URL=
# Optional Discord thread id (falls back to ALERT_WEBHOOK_THREAD_ID).
RECOVERY_WEBHOOK_THREAD_ID=
RECOVERY_WEBHOOK_TIMEOUT_SECONDS=5
RECOVERY_WEBHOOK_USERNAME="BetBot Recovery"
# suppress duplicate notifications unless payload meaningfully changed.
RECOVERY_NOTIFY_STATUS_CHANGE_ONLY=1
# concise or detailed
RECOVERY_WEBHOOK_MESSAGE_MODE=concise
RECOVERY_ALERT_STATE_FILE=

# Nightly chaos drill (safe by default: auto-skips when ALLOW_LIVE_ORDERS=1).
RECOVERY_CHAOS_DIR=
RECOVERY_CHAOS_LOG_FILE=
RECOVERY_CHAOS_LATEST_FILE=
RECOVERY_CHAOS_LOCK_FILE=/tmp/betbot-temperature-recovery-chaos.lock
RECOVERY_CHAOS_MAX_EVENT_FILES=120
RECOVERY_CHAOS_STOP_SECONDS=2
RECOVERY_CHAOS_WAIT_RECOVER_SECONDS=120
# Also drill alpha/breadth worker self-healing during chaos checks.
RECOVERY_CHAOS_ENABLE_WORKER_DRILLS=1
RECOVERY_CHAOS_WORKER_WAIT_RECOVER_SECONDS=90
RECOVERY_CHAOS_NOTIFY_ON_PASS=0
RECOVERY_CHAOS_WEBHOOK_URL=
# Optional Discord thread id (falls back to RECOVERY_WEBHOOK_THREAD_ID, then ALERT_WEBHOOK_THREAD_ID).
RECOVERY_CHAOS_WEBHOOK_THREAD_ID=
RECOVERY_CHAOS_WEBHOOK_TIMEOUT_SECONDS=5
RECOVERY_CHAOS_WEBHOOK_USERNAME="BetBot Recovery Drill"
# concise or detailed
RECOVERY_CHAOS_WEBHOOK_MESSAGE_MODE=concise

# Stale-metrics adaptive guardrail drill (periodic chaos-lite validation).
# This drill runs shadow in an isolated temp output dir with tight metric-age
# thresholds, and verifies stale artifacts do not drive data-dependent
# adaptive decisions.
STALE_METRICS_DRILL_TIMER_EXPECTED=1
STALE_METRICS_DRILL_FAIL_ON_DRILL_FAILURE=1
STALE_METRICS_DRILL_ALERT_ENABLED=1
# Falls back to RECOVERY_CHAOS_WEBHOOK_URL, then RECOVERY_WEBHOOK_URL,
# then ALERT_WEBHOOK_URL when unset.
STALE_METRICS_DRILL_ALERT_WEBHOOK_URL=
# Optional Discord thread id (falls back to RECOVERY_CHAOS_WEBHOOK_THREAD_ID,
# then RECOVERY_WEBHOOK_THREAD_ID, then ALERT_WEBHOOK_THREAD_ID).
STALE_METRICS_DRILL_ALERT_WEBHOOK_THREAD_ID=
STALE_METRICS_DRILL_ALERT_WEBHOOK_TIMEOUT_SECONDS=5
STALE_METRICS_DRILL_ALERT_WEBHOOK_USERNAME="BetBot Stale Drill"
# Set to 1 if you want pass notifications too (defaults to fail-only).
STALE_METRICS_DRILL_ALERT_NOTIFY_ON_PASS=0
# Suppress duplicate alerts unless status/failure fingerprint changes.
STALE_METRICS_DRILL_ALERT_NOTIFY_STATUS_CHANGE_ONLY=1
# concise or detailed
STALE_METRICS_DRILL_ALERT_MESSAGE_MODE=concise
# Optional persisted alert state path. Defaults under
# $OUTPUT_DIR/recovery_chaos/stale_metrics_drill/.alert_state.json
STALE_METRICS_DRILL_ALERT_STATE_FILE=
