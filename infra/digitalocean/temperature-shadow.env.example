LOG_MAINTENANCE_PRUNE_DAYS=21
LOG_MAINTENANCE_GZIP_LEVEL=6
LOG_MAINTENANCE_MAX_BYTES_WARN=21474836480
LOG_MAINTENANCE_MAX_BYTES_CRIT=42949672960
# Optional override path for logrotate installer script.
LOG_MAINTENANCE_INSTALLER_SCRIPT=
# Optional log-pressure webhook alerting from maintenance cycles.
LOG_MAINT_ALERT_ENABLED=1
# Falls back to ALERT_WEBHOOK_URL when unset.
LOG_MAINT_ALERT_WEBHOOK_URL=
# Optional Discord thread id (falls back to ALERT_WEBHOOK_THREAD_ID).
LOG_MAINT_ALERT_WEBHOOK_THREAD_ID=
LOG_MAINT_ALERT_WEBHOOK_TIMEOUT_SECONDS=5
LOG_MAINT_ALERT_WEBHOOK_USERNAME="BetBot Ops"
# Suppress duplicate alerts for same status/reason within minimum interval.
LOG_MAINT_ALERT_NOTIFY_STATUS_CHANGE_ONLY=1
LOG_MAINT_ALERT_MIN_INTERVAL_SECONDS=10800
# Trigger yellow/green growth alerts when usage increases faster than this.
LOG_MAINT_ALERT_GROWTH_BYTES_THRESHOLD=1073741824
# concise or detailed
LOG_MAINT_ALERT_MESSAGE_MODE=concise
# Optional persisted alert dedupe state file.
LOG_MAINT_ALERT_STATE_FILE=

# Optional periodic Discord route guard
# (used by run_temperature_discord_route_guard.sh / install_systemd_temperature_discord_route_guard.sh).
DISCORD_ROUTE_GUARD_ENABLED=1
# strict=1 marks shared webhook+thread routes as red.
DISCORD_ROUTE_GUARD_STRICT=1
# optional strict-check override for check_temperature_shadow.sh:
# when unset, strict mode auto-enforces this if route-guard timer is installed.
DISCORD_ROUTE_GUARD_TIMER_EXPECTED=
# optional strict-check collision policy override for check_temperature_shadow.sh:
# when unset, strict mode auto-fails on non-green route guard when expected.
DISCORD_ROUTE_GUARD_STRICT_FAIL_ON_COLLISION=
# legacy/shared override. If set, may also influence route-guard service behavior
# in older deployments. Prefer DISCORD_ROUTE_GUARD_STRICT_FAIL_ON_COLLISION for
# strict health checks and DISCORD_ROUTE_GUARD_SERVICE_FAIL_ON_COLLISION for the service.
DISCORD_ROUTE_GUARD_FAIL_ON_COLLISION=
# optional service behavior override for run_temperature_discord_route_guard.sh:
# keep at 0/unset so service reports red/yellow without failing systemd.
DISCORD_ROUTE_GUARD_SERVICE_FAIL_ON_COLLISION=0
# falls back to LOG_MAINT_ALERT_WEBHOOK_URL, then RECOVERY_WEBHOOK_URL, then ALERT_WEBHOOK_URL.
DISCORD_ROUTE_GUARD_WEBHOOK_URL=
# falls back to LOG_MAINT_ALERT_WEBHOOK_THREAD_ID, then RECOVERY_WEBHOOK_THREAD_ID, then ALERT_WEBHOOK_THREAD_ID.
DISCORD_ROUTE_GUARD_WEBHOOK_THREAD_ID=
DISCORD_ROUTE_GUARD_WEBHOOK_TIMEOUT_SECONDS=5
DISCORD_ROUTE_GUARD_WEBHOOK_USERNAME="BetBot Route Guard"
DISCORD_ROUTE_GUARD_NOTIFY_STATUS_CHANGE_ONLY=1
# concise or detailed
DISCORD_ROUTE_GUARD_MESSAGE_MODE=concise
# optional command text included in remediation alerts.
