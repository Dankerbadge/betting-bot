# Optional log rotation policy (used by install_logrotate_temperature_logs.sh).
# Keeps loop logs bounded so diagnostics stay fast and disk usage predictable.
BETBOT_LOG_DIR=
BETBOT_LOG_ROTATE_SIZE=100M
BETBOT_LOG_ROTATE_COUNT=14
BETBOT_LOG_ROTATE_DAILY=1
# Set to 1 for a one-time immediate rotation pass during install.
BETBOT_LOGROTATE_FORCE_NOW=0
# Logrotate executes with this user/group (default root/root is safest for mixed ownership logs).
BETBOT_LOGROTATE_SU_USER=root
BETBOT_LOGROTATE_SU_GROUP=root
# Optional periodic log-maintenance timer knobs
# (used by run_temperature_log_maintenance.sh / install_systemd_temperature_log_maintenance.sh).
LOG_MAINTENANCE_ENABLED=1
LOG_MAINTENANCE_RUN_LOGROTATE=1
LOG_MAINTENANCE_AUTO_INSTALL_LOGROTATE=1
