ARTIFACT_KEEP_CHECKPOINTS_LATEST=2000

# Optional dedicated 12h alpha summary timer inputs
# (used by run_temperature_alpha_summary.sh / install_systemd_temperature_alpha_summary.sh).
ALPHA_SUMMARY_HOURS=12
ALPHA_SUMMARY_TOP_N=10
ALPHA_SUMMARY_REFERENCE_BANKROLL_DOLLARS=1000
ALPHA_SUMMARY_SLIPPAGE_BPS_LIST=0,5,10
# Clamp range is 3-5 suggestions in message output.
ALPHA_SUMMARY_SUGGESTION_COUNT=5
# Approval guardrail for summary drift detection.
ALPHA_SUMMARY_APPROVAL_RATE_MIN=0.03
ALPHA_SUMMARY_APPROVAL_RATE_MAX=0.20
ALPHA_SUMMARY_APPROVAL_RATE_MIN_INTENTS=100
ALPHA_SUMMARY_APPROVAL_RATE_CRITICAL_HIGH=0.50
# Deploy-confidence safety caps for operator-facing summary:
# cap deploy confidence when bankroll projection is negative, and optionally when
# projected return does not exceed HYSA baseline.
ALPHA_SUMMARY_DEPLOY_CONFIDENCE_NEGATIVE_PNL_CAP=49
ALPHA_SUMMARY_DEPLOY_CONFIDENCE_HYSA_FAIL_CAP=54
ALPHA_SUMMARY_DEPLOY_CONFIDENCE_HYSA_FAIL_REQUIRES_SETTLED=1
# Guardrail basis hardening: only trust latest intents summary when sample size is
# large enough relative to the full window (prevents tiny latest sample drift).
ALPHA_SUMMARY_APPROVAL_GUARDRAIL_BASIS_MIN_RATIO_TO_WINDOW=0.25
ALPHA_SUMMARY_APPROVAL_GUARDRAIL_BASIS_MIN_ABS_INTENTS=1000
# Keep shadow-loop escalation aligned with summary basis floor so thresholds are
# not tightened from tiny one-cycle bursts.
APPROVAL_GUARDRAIL_ESCALATION_BASIS_MIN_ABS_INTENTS=1000
# Optional self-correcting guardrail mode (disabled by default for 12h cadence):
# after N consecutive guardrail breaches, alpha summary can write an auto
# approval-gate profile consumed by the shadow loop. Recommendation fitting uses
# rolling-window intent quality rows when available, so MIN_ROWS should reflect
# representative window volume rather than one-cycle snapshots.
ALPHA_SUMMARY_APPROVAL_AUTO_APPLY_ENABLED=0
ALPHA_SUMMARY_APPROVAL_AUTO_APPLY_STREAK_REQUIRED=1
# Keep >= ALPHA_SUMMARY_APPROVAL_GUARDRAIL_BASIS_MIN_ABS_INTENTS.
ALPHA_SUMMARY_APPROVAL_AUTO_APPLY_MIN_ROWS=1000
# Require stable window-over-window behavior before auto-apply writes a profile.
ALPHA_SUMMARY_APPROVAL_AUTO_APPLY_STABILITY_ENABLED=1
ALPHA_SUMMARY_APPROVAL_AUTO_APPLY_STABILITY_WINDOWS_REQUIRED=2
ALPHA_SUMMARY_APPROVAL_AUTO_APPLY_STABILITY_MAX_APPROVAL_DELTA_PP=2.0
ALPHA_SUMMARY_APPROVAL_AUTO_APPLY_STABILITY_MAX_STALE_DELTA_PP=3.0
# When enabled, auto profile is removed after this many consecutive
# in-band guardrail summaries (prevents stale strict profile lock-in).
ALPHA_SUMMARY_APPROVAL_AUTO_RELEASE_ENABLED=1
ALPHA_SUMMARY_APPROVAL_AUTO_RELEASE_STREAK_REQUIRED=3
# Additional safety valve: release auto-applied profile if latest intents summary
# stays at zero approvals for N consecutive alpha-summary runs (with min intents).
# Keep this aligned with guardrail basis floor to avoid tiny-sample releases.
ALPHA_SUMMARY_APPROVAL_AUTO_RELEASE_ZERO_APPROVED_STREAK_REQUIRED=2
ALPHA_SUMMARY_APPROVAL_AUTO_RELEASE_ZERO_APPROVED_MIN_INTENTS=1000
ALPHA_SUMMARY_APPROVAL_AUTO_APPLY_STATE_FILE=/opt/betting-bot/outputs/pilot_candidate_do/runtime/approval_guardrail_auto_apply_state.json
ALPHA_SUMMARY_APPROVAL_AUTO_APPLY_PROFILE_FILE=/opt/betting-bot/outputs/pilot_candidate_do/runtime/approval_gate_profile_auto.json
# Quality drift alert (window-over-window): flag large approval-rate moves that
# are not accompanied by independent breadth growth.
ALPHA_SUMMARY_QUALITY_DRIFT_APPROVAL_DELTA_PP_MIN=3.0
ALPHA_SUMMARY_QUALITY_DRIFT_MIN_INTENTS_PER_WINDOW=1000
ALPHA_SUMMARY_QUALITY_DRIFT_MAX_RESOLVED_SIDES_DELTA=0
# Parameter-enforcement coverage alert (approved rows): flag when approval
# throughput is no longer grounded in edge/probability/alpha gate evidence.
ALPHA_SUMMARY_GATE_COVERAGE_ALERT_MIN_APPROVED_ROWS=1000
ALPHA_SUMMARY_GATE_COVERAGE_EXPECTED_EDGE_MIN=0.60
ALPHA_SUMMARY_GATE_COVERAGE_PROBABILITY_MIN=0.60
ALPHA_SUMMARY_GATE_COVERAGE_ALPHA_MIN=0.30
# Optional gate-coverage auto-apply trigger (disabled by default): if coverage
